generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  other
}

enum Goal {
  relationship
  communication
  workout_partner
}

enum TrainingTimeSlot {
  morning
  day
  evening
  weekends
}

enum TrainingType {
  strength
  cardio
  crossfit
  yoga
}

enum ExternalProvider {
  yandex
  dgis
  other
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  phone             String             @unique
  passwordHash      String
  name              String
  age               Int
  gender            Gender
  description       String?
  photos            String[]
  isVerified        Boolean            @default(false)
  city              String
  /** Административный округ (напр. ЦАО, САО) или субъект РФ для малых городов */
  okrug             String?
  /** Район города (напр. Тверской) или зона внутри города */
  district          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  memberships       UserGymMembership[]
  likesSent         Like[]             @relation("LikesSent")
  likesReceived     Like[]             @relation("LikesReceived")
  matchesA          Match[]            @relation("MatchUserA")
  matchesB          Match[]            @relation("MatchUserB")
  messages          Message[]
  goals             UserGoal[]
  trainingSlots     UserTrainingSlot[]
  trainingTypes     UserTrainingType[]
  refreshSessions   RefreshSession[]
  blocksInitiated   Block[]             @relation("Blocker")
  blocksReceived    Block[]             @relation("Blocked")
  reportsInitiated  Report[]            @relation("Reporter")
  reportsReceived   Report[]            @relation("Reported")
  gymSuggestions    GymSuggestion[]
  isBanned          Boolean             @default(false)
  banReason         String?
  companyMemberships CompanyMember[]
  vprokOrders       VprokOrder[]
  vprokDisputes     VprokDispute[]
  vprokRiskEvents   VprokRiskEvent[]
  vprokTermsAcceptances VprokTermsAcceptance[]
}

model Gym {
  id                String             @id @default(cuid())
  name              String
  address           String
  city              String
  okrug             String?
  district          String?
  region            String?
  latitude          Float?
  longitude         Float?
  externalProvider  ExternalProvider?
  externalId        String?
  chainName         String?
  createdAt         DateTime           @default(now())
  memberships       UserGymMembership[]
  likes             Like[]
  matches           Match[]

  @@unique([externalProvider, externalId], map: "provider_external_unique")
  @@index([city])
  @@index([city, district])
  @@index([city, okrug, district])
}

/** Заявка пользователя: добавить зал/центр в каталог (модерация вручную). */
model GymSuggestion {
  id        String   @id @default(cuid())
  userId    String
  city      String
  okrug     String?
  district  String?
  name      String
  address   String
  details   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([city, createdAt])
  @@index([status, createdAt])
}

model UserGymMembership {
  id        String   @id @default(cuid())
  userId    String
  gymId     String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([userId, gymId])
  @@index([gymId])
}

model UserGoal {
  id     String @id @default(cuid())
  userId String
  goal   Goal
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, goal])
}

model UserTrainingSlot {
  id     String           @id @default(cuid())
  userId String
  slot   TrainingTimeSlot
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slot])
}

model UserTrainingType {
  id     String       @id @default(cuid())
  userId String
  type   TrainingType
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model Like {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  gymId      String
  createdAt  DateTime @default(now())
  fromUser   User     @relation("LikesSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("LikesReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  gym        Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId, gymId])
  @@index([toUserId, gymId])
}

model Match {
  id        String    @id @default(cuid())
  userAId   String
  userBId   String
  gymId     String
  createdAt DateTime  @default(now())
  userA     User      @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User      @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  gym       Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([userAId, userBId, gymId])
  @@index([userAId])
  @@index([userBId])
}

model Message {
  id        String   @id @default(cuid())
  matchId   String
  fromUserId String
  text      String
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  fromUser  User     @relation(fields: [fromUserId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
}

model RefreshSession {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Block {
  id          String   @id @default(cuid())
  blockerId   String
  blockedId   String
  createdAt   DateTime @default(now())
  blocker     User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked     User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  reportedId  String
  reason      String
  details     String?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?
  reporter    User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported    User     @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reportedId, status])
}

enum CompanyMemberRole {
  owner
  manager
}

enum VprokOrderStatus {
  pending_payment
  paid
  fulfilled
  refunded
  cancelled
}

enum VprokPaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum VprokDisputeStatus {
  open
  in_review
  resolved
  rejected
}

enum VprokRiskEventScope {
  order_create
  order_pay
}

enum VprokTermsType {
  platform
  seller
}

model Company {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  legalName   String?
  disputeEmail String?
  termsUrl    String?
  returnPolicyText String?
  isVerified  Boolean         @default(false)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  members     CompanyMember[]
  products    VprokProduct[]
  orders      VprokOrder[]
  disputes    VprokDispute[]
}

model CompanyMember {
  id        String            @id @default(cuid())
  companyId String
  userId    String
  role      CompanyMemberRole @default(manager)
  createdAt DateTime          @default(now())
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
}

model VprokProduct {
  id                 String           @id @default(cuid())
  companyId          String
  title              String
  description        String?
  imageUrl           String?
  unit               String
  sku                String?
  priceCents         Int
  minShelfLifeDays   Int
  substitutionPolicy String?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orderItems         VprokOrderItem[]

  @@index([companyId, isActive])
}

model VprokOrder {
  id             String           @id @default(cuid())
  userId         String
  companyId      String
  status         VprokOrderStatus @default(pending_payment)
  /** Сумма к оплате покупателем (грязная), копейки */
  totalCents     Int
  /** Комиссия платформы в bps (например 300 = 3%) */
  platformFeeBps Int              @default(300)
  /** Комиссия платформы в копейках */
  platformFeeCents Int             @default(0)
  /** Остаток к перечислению ритейлеру после удержания комиссии */
  retailerPayoutCents Int          @default(0)
  pickupDeadline DateTime?
  sellerTermsSnapshot String?
  paidAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items          VprokOrderItem[]
  payments       VprokPayment[]
  disputes       VprokDispute[]
  paymentEvents  VprokPaymentEvent[]
  riskEvents     VprokRiskEvent[]
  termsAcceptances VprokTermsAcceptance[]

  @@index([userId, createdAt])
  @@index([companyId, createdAt])
}

model VprokOrderItem {
  id                String     @id @default(cuid())
  orderId           String
  productId         String
  titleSnapshot     String
  unitSnapshot      String
  quantity          Int
  unitPriceCents    Int
  subtotalCents     Int
  createdAt         DateTime   @default(now())
  order             VprokOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           VprokProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model VprokPayment {
  id               String            @id @default(cuid())
  orderId          String
  provider         String
  providerPaymentId String?
  status           VprokPaymentStatus @default(pending)
  amountCents      Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  order            VprokOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events           VprokPaymentEvent[]

  @@index([orderId, status])
  @@unique([provider, providerPaymentId])
}

model VprokPaymentEvent {
  id               String       @id @default(cuid())
  externalEventId  String       @unique
  paymentId        String?
  orderId          String
  provider         String
  status           VprokPaymentStatus
  amountCents      Int
  payload          String
  createdAt        DateTime     @default(now())
  payment          VprokPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  order            VprokOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model VprokDispute {
  id             String            @id @default(cuid())
  orderId        String
  userId         String
  companyId      String
  status         VprokDisputeStatus @default(open)
  buyerMessage   String
  sellerResponse String?
  resolutionNote String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  order          VprokOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@index([companyId, createdAt])
  @@index([userId, createdAt])
}

model VprokRiskEvent {
  id        String             @id @default(cuid())
  userId    String
  orderId   String?
  scope     VprokRiskEventScope
  code      String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     VprokOrder?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([scope, code, createdAt])
  @@index([orderId, createdAt])
}

model VprokTermsAcceptance {
  id           String         @id @default(cuid())
  userId       String
  orderId      String?
  termsType    VprokTermsType
  termsVersion String
  acceptedAt   DateTime       @default(now())
  ipAddress    String?
  userAgent    String?
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  order        VprokOrder?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, acceptedAt])
  @@index([termsType, termsVersion, acceptedAt])
  @@index([orderId, acceptedAt])
}
