# Staging (docker compose -f docker-compose.yml -f docker-compose.staging.yml --env-file .env.staging).
# Скопируй в .env.staging и выставь свои пароли/секреты — не те же, что в проде.

EDEM_DB_PASSWORD=staging_change_me

DATABASE_URL="postgresql://edem_app:staging_change_me@db:5432/edem?schema=public"
JWT_SECRET="staging_jwt_at_least_16_chars"
ADMIN_MODERATION_KEY="staging_admin_8plus"
VPROK_WEBHOOK_SECRET="staging_webhook_secret"
VPROK_PAYMENT_PROVIDER=mock
VPROK_PLATFORM_FEE_BPS=300
PORT=3000

# Публичная копия: https://staging.edem.press (см. edem.press.nginx и docs/STAGING.md)
WEB_BASE_URL="https://staging.edem.press"
CORS_ALLOW_ORIGINS="https://staging.edem.press"
# Локально без домена: http://127.0.0.1:8081 (CORS для localhost уже разрешён в API)
# WEB_BASE_URL="http://127.0.0.1:8081"
