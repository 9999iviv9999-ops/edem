# Локально без Docker: свой Postgres. В Docker см. .env.docker.example (хост db, БД edem).
DATABASE_URL="postgresql://edem_app:edem_app_2026@localhost:5432/edem?schema=public"
JWT_SECRET="change_me_to_long_random_secret"
# 0 = access-токен без срока (всегда авторизован, пока не «Выйти» / бан / смена JWT_SECRET). Иначе — минуты.
ACCESS_TOKEN_TTL_MINUTES=0
# Запись refresh в БД (по умолчанию ~100 лет; «Выйти везде» всё равно отзывает).
REFRESH_TOKEN_TTL_DAYS=36500
ADMIN_MODERATION_KEY="change_me_admin_key"

# Опционально: публичный бейдж в профиле (виден всем). При логине/регистрации выставляется пользователю с этим номером.
# VIP_PROFILE_BADGE_PHONE="+79123456789"
# VIP_PROFILE_BADGE_LABEL="Founder Diamond"
S3_ENDPOINT=""
S3_REGION="ru-central1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL_BASE=""
PORT=3000

# Опционально: алерты cron (smoke-with-alert, api-self-heal) в Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Опционально: живой поиск залов (см. GymPicker в веб-клиенте)
# 2ГИС — https://platform.2gis.ru/
DGIS_API_KEY=
# Яндекс — Поиск по организациям (Geosearch) — https://developer.tech.yandex.ru/
YANDEX_MAPS_API_KEY=
VPROK_WEBHOOK_SECRET="change_me_vprok_webhook_secret"
VPROK_PAYMENT_PROVIDER="mock"
# 300 = 3% от суммы заказа (удерживается из оплаты покупателя; остаток — ритейлеру)
VPROK_PLATFORM_FEE_BPS=300
GOOGLE_CLIENT_ID=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
# Должен совпадать с redirect URL в настройках VK приложения:
# https://api.edem.press/api/auth/social/vk/callback
VK_REDIRECT_URI=
# Куда редиректить пользователя после успешного VK-входа
WEB_BASE_URL="https://edem.press"

# Принудительно перезалить залы из prisma/gyms-generated.json (иначе сид пропускается, если каталог уже в БД)
# FORCE_GYM_SEED=1
