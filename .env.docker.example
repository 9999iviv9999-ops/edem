# Docker Compose: API и контейнер Postgres `db` в одном проекте (отдельно от vprok и др.).
# Скопируй в .env в корне репозитория.
#
# Пароль ниже должен совпадать с EDEM_DB_PASSWORD в этом же .env (или оставь дефолт edem_app_2026 везде).
EDEM_DB_PASSWORD=edem_app_2026

DATABASE_URL="postgresql://edem_app:edem_app_2026@db:5432/edem?schema=public"
JWT_SECRET="минимум_16_символов_случайная_строка"
ADMIN_MODERATION_KEY="минимум_8_символов"
# VIP_PROFILE_BADGE_PHONE="+79123456789"
# VIP_PROFILE_BADGE_LABEL="Founder Diamond"
VPROK_WEBHOOK_SECRET="случайная_строка_для_webhook"
VPROK_PAYMENT_PROVIDER="mock"
VPROK_PLATFORM_FEE_BPS=300
PORT=3000
