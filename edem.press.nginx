server {
    listen 80;
    listen [::]:80;
    server_name edem.press;
    return 301 https://edem.press$request_uri;
}

server {
    listen 80;
    listen [::]:80;
    server_name www.edem.press app.edem.press;
    return 301 https://edem.press$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name www.edem.press app.edem.press;

    ssl_certificate /etc/letsencrypt/live/edem.press/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/edem.press/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://edem.press$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name edem.press;

    client_max_body_size 20m;
    include /etc/nginx/snippets/edem-press-stg-path.conf;

    ssl_certificate /etc/letsencrypt/live/edem.press/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/edem.press/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Жёсткий лимит на брутфорс: подключи ops/nginx-http-snippet-edem.conf в http {}, затем раскомментируй limit_req.
    location /api/auth/ {
        limit_req zone=edem_api_auth burst=45 nodelay;
        proxy_pass http://127.0.0.1:3000/api/auth/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 75s;
        proxy_send_timeout 75s;
        proxy_read_timeout 75s;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:3000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 75s;
        proxy_send_timeout 75s;
        proxy_read_timeout 75s;
    }

    # Фото с диска API — напрямую на Node (и без кэша SW на другом origin-path).
    location /uploads/ {
        proxy_pass http://127.0.0.1:3000/uploads/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 75s;
        proxy_send_timeout 75s;
        proxy_read_timeout 75s;
    }

    location / {
        proxy_pass http://127.0.0.1:8080/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 75s;
        proxy_send_timeout 75s;
        proxy_read_timeout 75s;
    }
}

# Если с ПК открывается, а с мобильного «нет соединения»: проверьте запись AAAA у edem.press
# (битый IPv6 часто даёт таймаут только с части сетей), fail2ban/ufw и что контейнер edem-web пересобран.
